{
  "name": "vite-config-multi",
  "version": "1.0.1",
  "description": "A vite multi entry build system config helper",
  "main": "./dist/vite.config.multi.js",
  "module": "./dist/vite.config.multi.js",
  "types": "./typings/index.d.ts",
  "exports": {
    ".": {
      "types": "./typings/vite.config.multi.d.ts",
      "import": "./dist/vite.config.multi.js"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "typings"
  ],
  "scripts": {
    "dev": "vite build --mode development",
    "build": "vite build",
    "dts": "tsc --emitDeclarationOnly --declaration --declarationDir ./typings"
  },
  "author": " <danielr@electroteque.org> (https://github.com/danielr)",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "run",
    "private",
    "fields",
    "node"
  ]
}
